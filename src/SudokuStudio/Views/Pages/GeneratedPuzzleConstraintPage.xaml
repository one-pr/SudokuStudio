<Page
	x:Class="SudokuStudio.Views.Pages.GeneratedPuzzleConstraintPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:categorization="using:Sudoku.Analytics.Categorization"
	xmlns:con="using:Sudoku.Filtering.Constraints"
	xmlns:m="using:SudokuStudio.Markup"
	xmlns:p="using:SudokuStudio.Views.Pages"
	mc:Ignorable="d" d:DataContext="{d:DesignInstance Type=p:GeneratedPuzzleConstraintPage}">
	<Grid RowDefinitions="*,Auto">
		<ScrollViewer Grid.Row="0">
			<StackPanel Margin="{StaticResource ContentAlignedWithNavigationViewHeaderMargin}" Spacing="4">
				<TextBlock Text="{m:R Key=GeneratedPuzzleConstraintPage_Intro}" Margin="0,10,0,0" />
				<ListView ItemsSource="{x:Bind _controls,Mode=OneWay}" SelectionMode="None" />
			</StackPanel>
		</ScrollViewer>
		<Border
			Grid.Row="1" BorderThickness="0,2,0,0" Margin="{StaticResource ContentAlignedWithNavigationViewHeaderMargin}"
			BorderBrush="{ThemeResource SolvingStepItemForeground}">
			<Grid ColumnDefinitions="Auto,*">
				<Button Grid.Column="0" Content="{m:R Key=GeneratedPuzzleConstraintPage_AddNewConstraint}" Margin="12,12,30,12">
					<Button.Flyout>
						<MenuFlyout x:Name="MenuFlyout" Opening="MenuFlyout_Opening">
							<!--#region Technique related-->
							<!--CountBetweenConstraint-->
							<MenuFlyoutItem
								Text="{m:R Key=GeneratedPuzzleConstraintPage_CountBetweenConstraint}"
								Click="MenuFlyoutItem_Click"
								PointerEntered="MenuFlyoutItem_PointerEntered"
								PointerExited="MenuFlyoutItem_PointerExited">
								<MenuFlyoutItem.Tag>
									<con:CountBetweenConstraint Range="{m:Range Range='24..28'}" CellState="Given" BetweenRule="BothClosed" />
								</MenuFlyoutItem.Tag>
							</MenuFlyoutItem>

							<!--SymmetryConstraint-->
							<MenuFlyoutItem
								Text="{m:R Key=GeneratedPuzzleConstraintPage_SymmetryConstraint}"
								Click="MenuFlyoutItem_Click"
								PointerEntered="MenuFlyoutItem_PointerEntered"
								PointerExited="MenuFlyoutItem_PointerExited">
								<MenuFlyoutItem.Tag>
									<con:SymmetryConstraint SymmetricTypes="Central" />
								</MenuFlyoutItem.Tag>
							</MenuFlyoutItem>

							<!--TechniqueConstraint-->
							<MenuFlyoutItem
								Text="{m:R Key=GeneratedPuzzleConstraintPage_TechniqueConstraint}"
								Click="MenuFlyoutItem_Click"
								PointerEntered="MenuFlyoutItem_PointerEntered"
								PointerExited="MenuFlyoutItem_PointerExited">
								<MenuFlyoutItem.Tag>
									<con:TechniqueConstraint>
										<con:TechniqueConstraint.Techniques>
											<categorization:Technique>LockedPair</categorization:Technique>
											<categorization:Technique>LockedTriple</categorization:Technique>
										</con:TechniqueConstraint.Techniques>
									</con:TechniqueConstraint>
								</MenuFlyoutItem.Tag>
							</MenuFlyoutItem>

							<!--TechniqueSetConstraint-->
							<MenuFlyoutItem
								Text="{m:R Key=GeneratedPuzzleConstraintPage_TechniqueSetConstraint}"
								Click="MenuFlyoutItem_Click"
								PointerEntered="MenuFlyoutItem_PointerEntered"
								PointerExited="MenuFlyoutItem_PointerExited">
								<MenuFlyoutItem.Tag>
									<con:TechniqueSetConstraint>
										<con:TechniqueSetConstraint.Techniques>
											<categorization:Technique>FullHouse</categorization:Technique>
											<categorization:Technique>LastDigit</categorization:Technique>
											<categorization:Technique>CrosshatchingBlock</categorization:Technique>
										</con:TechniqueSetConstraint.Techniques>
									</con:TechniqueSetConstraint>
								</MenuFlyoutItem.Tag>
							</MenuFlyoutItem>

							<!--TechniqueCountConstraint-->
							<MenuFlyoutItem
								Text="{m:R Key=GeneratedPuzzleConstraintPage_TechniqueCountConstraint}"
								Click="MenuFlyoutItem_Click"
								PointerEntered="MenuFlyoutItem_PointerEntered"
								PointerExited="MenuFlyoutItem_PointerExited">
								<MenuFlyoutItem.Tag>
									<con:TechniqueCountConstraint Technique="NakedSingle" LimitCount="1" Operator="GreaterThanOrEqual" />
								</MenuFlyoutItem.Tag>
							</MenuFlyoutItem>

							<!--TechniquePrecedenceConstraint-->
							<MenuFlyoutItem
								Text="{m:R Key=GeneratedPuzzleConstraintPage_TechniquePrecedenceConstraint}"
								Click="MenuFlyoutItem_Click"
								PointerEntered="MenuFlyoutItem_PointerEntered"
								PointerExited="MenuFlyoutItem_PointerExited">
								<MenuFlyoutItem.Tag>
									<con:TechniquePrecedenceConstraint
										TargetTechnique="NakedPair"
										ComparedTechnique="Pointing"
										Operator="Predecessor" />
								</MenuFlyoutItem.Tag>
							</MenuFlyoutItem>

							<!--TechniqueGroupCountConstraint-->
							<MenuFlyoutItem
								Text="{m:R Key=GeneratedPuzzleConstraintPage_TechniqueGroupCountConstraint}"
								Click="MenuFlyoutItem_Click"
								PointerEntered="MenuFlyoutItem_PointerEntered"
								PointerExited="MenuFlyoutItem_PointerExited">
								<MenuFlyoutItem.Tag>
									<con:TechniqueGroupCountConstraint TechniqueGroup="Subset" LimitCount="3" Operator="Equality" />
								</MenuFlyoutItem.Tag>
							</MenuFlyoutItem>

							<MenuFlyoutSeparator />
							<!--#endregion-->

							<!--#region Information related-->
							<!--EliminationCountConstraint-->
							<MenuFlyoutItem
								Text="{m:R Key=GeneratedPuzzleConstraintPage_EliminationCountConstraint}"
								Click="MenuFlyoutItem_Click"
								PointerEntered="MenuFlyoutItem_PointerEntered"
								PointerExited="MenuFlyoutItem_PointerExited">
								<MenuFlyoutItem.Tag>
									<con:EliminationCountConstraint Technique="LockedPair" LimitCount="5" Operator="GreaterThanOrEqual" />
								</MenuFlyoutItem.Tag>
							</MenuFlyoutItem>

							<!--DifficultyLevelConstraint-->
							<MenuFlyoutItem
								Text="{m:R Key=GeneratedPuzzleConstraintPage_DifficultyLevelConstraint}"
								Click="MenuFlyoutItem_Click"
								PointerEntered="MenuFlyoutItem_PointerEntered"
								PointerExited="MenuFlyoutItem_PointerExited">
								<MenuFlyoutItem.Tag>
									<con:DifficultyLevelConstraint DifficultyLevel="Easy" Operator="Equality" />
								</MenuFlyoutItem.Tag>
							</MenuFlyoutItem>

							<!--ConclusionConstraint-->
							<MenuFlyoutItem
								Text="{m:R Key=GeneratedPuzzleConstraintPage_ConclusionConstraint}"
								Click="MenuFlyoutItem_Click"
								PointerEntered="MenuFlyoutItem_PointerEntered"
								PointerExited="MenuFlyoutItem_PointerExited">
								<MenuFlyoutItem.Tag>
									<con:ConclusionConstraint Conclusion="{m:Conclusion Text='r5c5 = 5'}" ShouldAppear="True" />
								</MenuFlyoutItem.Tag>
							</MenuFlyoutItem>

							<!--BottleneckTechniqueConstraint-->
							<MenuFlyoutItem
								Text="{m:R Key=GeneratedPuzzleConstraintPage_BottleneckTechniqueConstraint}"
								Click="MenuFlyoutItem_Click"
								PointerEntered="MenuFlyoutItem_PointerEntered"
								PointerExited="MenuFlyoutItem_PointerExited">
								<MenuFlyoutItem.Tag>
									<con:BottleneckTechniqueConstraint IsNegated="False">
										<con:BottleneckTechniqueConstraint.Techniques>
											<categorization:Technique>LockedPair</categorization:Technique>
											<categorization:Technique>LockedTriple</categorization:Technique>
										</con:BottleneckTechniqueConstraint.Techniques>
									</con:BottleneckTechniqueConstraint>
								</MenuFlyoutItem.Tag>
							</MenuFlyoutItem>

							<MenuFlyoutSeparator />

							<!--#endregion-->
							
							<!--#region Puzzle feature related-->

							<!--MissingDigitConstraint-->
							<MenuFlyoutItem
								Text="{m:R Key=GeneratedPuzzleConstraintPage_MissingDigitConstraint}"
								Click="MenuFlyoutItem_Click"
								PointerEntered="MenuFlyoutItem_PointerEntered"
								PointerExited="MenuFlyoutItem_PointerExited">
								<MenuFlyoutItem.Tag>
									<con:MissingDigitConstraint Digit="4" />
								</MenuFlyoutItem.Tag>
							</MenuFlyoutItem>

							<!--EmptyHousesCountConstraint-->
							<MenuFlyoutItem
								Text="{m:R Key=GeneratedPuzzleConstraintPage_EmptyHousesCountConstraint}"
								Click="MenuFlyoutItem_Click"
								PointerEntered="MenuFlyoutItem_PointerEntered"
								PointerExited="MenuFlyoutItem_PointerExited">
								<MenuFlyoutItem.Tag>
									<con:EmptyHousesCountConstraint HouseType="Block" Count="1" />
								</MenuFlyoutItem.Tag>
							</MenuFlyoutItem>

							<MenuFlyoutSeparator />
							<!--#endregion-->

							<!--#region Puzzle attributes related-->
							<!--PearlConstraint-->
							<MenuFlyoutItem
								Text="{m:R Key=GeneratedPuzzleConstraintPage_PearlConstraint}"
								Click="MenuFlyoutItem_Click"
								PointerEntered="MenuFlyoutItem_PointerEntered"
								PointerExited="MenuFlyoutItem_PointerExited">
								<MenuFlyoutItem.Tag>
									<con:PearlConstraint ShouldBePearlOrDiamond="False" />
								</MenuFlyoutItem.Tag>
							</MenuFlyoutItem>

							<!--DiamondConstraint-->
							<MenuFlyoutItem
								Text="{m:R Key=GeneratedPuzzleConstraintPage_DiamondConstraint}"
								Click="MenuFlyoutItem_Click"
								PointerEntered="MenuFlyoutItem_PointerEntered"
								PointerExited="MenuFlyoutItem_PointerExited">
								<MenuFlyoutItem.Tag>
									<con:DiamondConstraint ShouldBePearlOrDiamond="False" />
								</MenuFlyoutItem.Tag>
							</MenuFlyoutItem>

							<!--MinimalConstraint-->
							<MenuFlyoutItem
								Text="{m:R Key=GeneratedPuzzleConstraintPage_MinimalConstraint}"
								Click="MenuFlyoutItem_Click"
								PointerEntered="MenuFlyoutItem_PointerEntered"
								PointerExited="MenuFlyoutItem_PointerExited">
								<MenuFlyoutItem.Tag>
									<con:MinimalConstraint ShouldBeMinimal="False" />
								</MenuFlyoutItem.Tag>
							</MenuFlyoutItem>

							<MenuFlyoutSeparator />
							<!--#endregion-->

							<!--#region Miscellaneous features related-->
							<!--IttoryuConstraint-->
							<MenuFlyoutItem
								Text="{m:R Key=GeneratedPuzzleConstraintPage_IttoryuConstraint}"
								Click="MenuFlyoutItem_Click"
								PointerEntered="MenuFlyoutItem_PointerEntered"
								PointerExited="MenuFlyoutItem_PointerExited">
								<MenuFlyoutItem.Tag>
									<con:IttoryuConstraint LimitedSingle="NakedSingle" Operator="Equality" Rounds="1" />
								</MenuFlyoutItem.Tag>
							</MenuFlyoutItem>

							<!--PrimarySingleConstraint-->
							<MenuFlyoutItem
								Text="{m:R Key=GeneratedPuzzleConstraintPage_PrimarySingleConstraint}"
								Click="MenuFlyoutItem_Click"
								PointerEntered="MenuFlyoutItem_PointerEntered"
								PointerExited="MenuFlyoutItem_PointerExited">
								<MenuFlyoutItem.Tag>
									<con:PrimarySingleConstraint Primary="HiddenSingle" AllowsHiddenSingleInLines="False" />
								</MenuFlyoutItem.Tag>
							</MenuFlyoutItem>

							<!--LastingConstraint-->
							<MenuFlyoutItem
								Text="{m:R Key=GeneratedPuzzleConstraintPage_LastingConstraint}"
								Click="MenuFlyoutItem_Click"
								PointerEntered="MenuFlyoutItem_PointerEntered"
								PointerExited="MenuFlyoutItem_PointerExited">
								<MenuFlyoutItem.Tag>
									<con:LastingConstraint TechniqueFlag="NakedSingle" LimitCount="3" Operator="Equality" />
								</MenuFlyoutItem.Tag>
							</MenuFlyoutItem>
							<!--#endregion-->
						</MenuFlyout>
					</Button.Flyout>
				</Button>
				<TextBlock x:Name="DescriptionDisplayer" Grid.Column="1" FontWeight="Bold" VerticalAlignment="Center" />
			</Grid>
		</Border>
	</Grid>
</Page>
